# ==============================================
# NODE.JS / JAVASCRIPT / TYPESCRIPT
# ==============================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
**/dist/
**/build/
**/.cache/

# TypeScript compilation outputs
*.js
*.js.map
*.d.ts
# Keep important JS config files
!*.config.js
!*.config.cjs

# ==============================================
# ENVIRONMENT & SECRETS
# ==============================================
# Environment files
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# API keys and secrets
secrets/
*.key
*.pem

# ==============================================
# DEVELOPMENT TOOLS
# ==============================================
# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.bak

# Logs and debugging
logs/
*.log

# Testing
coverage/
.nyc_output/
.coverage
htmlcov/

